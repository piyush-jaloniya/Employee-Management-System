# Auto detect text files and normalize line endings to LF
* text=auto

# Java files
*.java text eol=lf
*.xml text eol=lf
*.sql text eol=lf
*.properties text eol=lf

# Web files
*.jsp text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf
README.md text eol=lf merge=union

# Build files
pom.xml text eol=lf
Dockerfile text eol=lf
*.gradle text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Binary files
*.jar binary
*.war binary
*.class binary
*.db binary
*.mv.db binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
